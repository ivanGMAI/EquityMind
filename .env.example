# LLM-провайдер: нужен хотя бы один ключ, иначе AI-комментарии отключены
# (метрики и графики работают и без ключей).
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# Модель (для OpenRouter можно бесплатную: ...:free)
EQUITYMIND_LLM_MODEL=claude-opus-4-8

# Принудительный выбор бэкенда: anthropic | openrouter | mock (пусто = автовыбор)
EQUITYMIND_LLM_PROVIDER=

# Альтернативный OpenAI-совместимый хост вместо OpenRouter (ключ тогда — в
# OPENROUTER_API_KEY). Например, cloud.ru foundation models:
# EQUITYMIND_LLM_BASE_URL=https://foundation-models.api.cloud.ru/v1
EQUITYMIND_LLM_BASE_URL=

EQUITYMIND_CONFIG=config/config.yaml

# Telegram-уведомления (опционально)
EQUITYMIND_TELEGRAM_TOKEN=
EQUITYMIND_TELEGRAM_CHAT_ID=
